# Copia este archivo como .env y llena los valores
# ¡NUNCA subas el .env real a git!

# --- Base de Datos ---
DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD_AQUI@localhost:5432/bar_la_catrina_v2

# --- JWT ---
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- App ---
APP_NAME=Bar La Catrina API
DEBUG=True
